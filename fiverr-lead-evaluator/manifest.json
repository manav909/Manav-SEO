{
  "manifest_version": 3,
  "name": "SEO Season — Fiverr Lead Evaluator",
  "version": "1.0.0",
  "description": "Evaluate Fiverr leads live from the open chat using your SEO Season intelligence engine. No copy-paste.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.fiverr.com/*",
    "https://seoseason.com/*",
    "https://*.seoseason.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SEO Season — settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.fiverr.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
