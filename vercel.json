{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "regions": [
    "iad1"
  ],
  "functions": {
    "api/intelligence.ts": {
      "maxDuration": 300,
      "regions": [
        "iad1"
      ]
    },
    "api/task-engine.ts": {
      "maxDuration": 300,
      "regions": [
        "iad1"
      ]
    },
    "api/run-analysis.ts": {
      "maxDuration": 300,
      "regions": [
        "iad1"
      ]
    },
    "api/crawl.ts": {
      "maxDuration": 300,
      "regions": [
        "iad1"
      ]
    },
    "api/seo-agent.ts": {
      "maxDuration": 300,
      "regions": [
        "iad1"
      ]
    },
    "api/analysis.ts": {
      "maxDuration": 300,
      "regions": [
        "iad1"
      ]
    },
    "api/playground-analysis.ts": {
      "maxDuration": 300,
      "regions": [
        "iad1"
      ]
    },
    "api/algorithm-intel.ts": {
      "maxDuration": 180,
      "regions": [
        "iad1"
      ]
    },
    "api/launchpad.ts": {
      "maxDuration": 120,
      "regions": [
        "iad1"
      ]
    },
    "api/auto-metrics.ts": {
      "maxDuration": 120,
      "regions": [
        "iad1"
      ]
    },
    "api/fetch-site-metrics.ts": {
      "maxDuration": 120,
      "regions": [
        "iad1"
      ]
    },
    "api/control.ts": {
      "maxDuration": 60,
      "regions": [
        "iad1"
      ]
    },
    "api/health-diagnostic.ts": {
      "maxDuration": 15,
      "regions": [
        "iad1"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
